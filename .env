# ============================================================================
# .env  —  Credentials & config for extract_thejar.py
# ============================================================================
#
# HOW TO USE
# ----------
# 1. Rename this file from `.env.example` to `.env` (drop the `.example`).
#    The script auto-loads `.env` from the directory you run it in.
# 2. Fill in your PlayByPoint email + password below.
# 3. NEVER commit this file to git. Add `.env` to your .gitignore.
#
# These are the same credentials you use to log in at
#   https://nplpickleball.playbypoint.com/users/sign_in
# (the "LOGIN TO CONTINUE" button on the booking page).
#
# If you don't have an account yet, sign up via the booking flow first —
# PlayByPoint requires a real account before showing slot data.
# ============================================================================

# --- REQUIRED -------------------------------------------------------------

PBP_EMAIL=blakerenfrey@yahoo.com.au
PBP_PASSWORD=Barkers16
SL_EMAIL=blakerenfrey@yahoo.com.au
SL_PASSWORD=Barkers16
SL_NAME=Blake Renfrey


# --- OPTIONAL -------------------------------------------------------------
# These override the script's defaults if set. Leave commented out to use
# the built-in defaults (which target The Jar | South Melbourne).

# Different PlayByPoint club? Override the slug and base URL:
# PBP_CLUB_SLUG=nplpickleball
# PBP_BASE_URL=https://nplpickleball.playbypoint.com
# PBP_BOOKING_URL=https://book.nplpickleball.com.au

# Route through a proxy (residential proxies help if Cloudflare keeps
# challenging you). Format: http://user:pass@host:port
# PBP_PROXY=

# Force visible browser by default (useful for debugging):
# PBP_HEADLESS=false
